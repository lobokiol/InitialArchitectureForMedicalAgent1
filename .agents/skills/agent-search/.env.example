# Agent Search API Keys
# 复制此文件为 .env 并填入你的 API Key

# Tavily API Key - AI 搜索引擎 (推荐主引擎)
# 获取地址: https://tavily.com
# 免费额度: 1000 credits/month
TAVILY_API_KEY=

# Brave Search API Key - Web 搜索补充 (可选)
# 获取地址: https://api-dashboard.search.brave.com/
# 需绑定银行卡；每月赠送 $5 credits，约 1000 次调用
BRAVE_API_KEY=

# Exa API Key - 语义补强 (可选)
# 获取地址: https://dashboard.exa.ai
# 当前公开 pricing 页显示每月最多 1000 requests 免费；无需绑定银行卡
EXA_API_KEY=

# Gemini API Key - 向量语义缓存 (推荐)
# 获取地址: https://aistudio.google.com/apikey
# 使用 gemini-embedding-001 模型生成查询向量
GEMINI_API_KEY=
