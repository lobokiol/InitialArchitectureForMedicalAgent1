DASHSCOPE_API_KEY="your_dashscope_api_key"

# Local services (default matches demo/docker-compose.local.yml)
ES_URL=http://localhost:9200
MILVUS_URI=http://localhost:19530
REDIS_URI=redis://localhost:6379
ES_INDEX_NAME=hospital_procedures
MILVUS_COLLECTION=medical_knowledge

# LLM (DashScope OpenAI-compatible)
CHAT_MODEL_NAME=qwen-plus
EMBEDDING_MODEL_NAME=text-embedding-v2
CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: true = 无 Docker/Redis 时本地演示（会话存内存，重启丢失）
USE_MEMORY_CHECKPOINTER=false
