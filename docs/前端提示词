  "user_id": "demo-user",
  "thread_id": "可选，省略则用当前会话",
  "message": "我头疼"
}
```

**响应**（`ChatResponse`，字段完整列表）

```typescript
interface ChatResponse {
  user_id: string;
  thread_id: string;
  reply: string;                          // Markdown
  intent_result?: IntentResult;
  used_docs: { medical: RetrievedDoc[]; process: RetrievedDoc[] };
  // --- 多轮导诊（前端必须处理）---
  awaiting_clarify: boolean;
  clarify_phase?: string;                 // age | sex | pain_location | ...
  clarify_choices: ClarifyChoice[];
  awaiting_dept_choice: boolean;
  dept_choices: DeptChoice[];
  multi_select: boolean;                  // true 时科室选项可多选
  // --- 置信度与结果 ---
  dept_confidence?: number;
  dept_confidence_passed?: boolean;
  dept_confidence_reason?: string;
  locked_department?: string;
  // --- 调试（演示页可折叠展示）---
  node_trace: string[];
  app_state?: Record<string, unknown>;
}

interface IntentResult {
  has_symptom: boolean;
  has_process: boolean;
  main_intent: 'symptom' | 'process' | 'mixed' | 'non_medical';
  symptom_query?: string;
  process_query?: string;
  triage_route?: 'disease' | 'symptom' | 'reject';
}

interface RetrievedDoc {
  id: string;
  source: 'medical' | 'process' | 'tool';
  title?: string;
  content: string;
  score?: number;
}

interface ClarifyChoice {
  id: string;
  label: string;
  slot?: string;
}

interface DeptChoice {
  id: string;
  label: string;
  target_departments: string[];
}
