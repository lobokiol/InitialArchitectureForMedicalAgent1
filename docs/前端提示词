#### 多轮交互伪代码（对齐 `cli.py`）

```typescript
async function chatUntilSettled(userId: string, threadId: string, message: string) {
  let data = await postChat({ user_id: userId, thread_id: threadId, message });

  while (data.awaiting_clarify && data.clarify_choices.length) {
  // 展示 data.reply + clarify_phase；用户点选 label
    const pick = await ui.pickSingle(data.clarify_choices.map(c => c.label));
    data = await postChat({ user_id: userId, thread_id: data.thread_id, message: pick });
  }

  while (data.awaiting_dept_choice && data.dept_choices.length) {
    const pick = data.multi_select
      ? await ui.pickMulti(data.dept_choices)   // 发送 "1,3" 或选项 label
      : await ui.pickSingle(data.dept_choices.map(c => c.label));
    data = await postChat({ user_id: userId, thread_id: data.thread_id, message: pick });
  }

  return data; // 最终 reply、intent_result、used_docs、dept_confidence...
}
```

