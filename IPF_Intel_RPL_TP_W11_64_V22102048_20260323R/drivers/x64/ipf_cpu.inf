; IPF EF Components
;----------------------------------------------------------------------

[IpfInstall_Win10_17763.NTamd64.Components]
AddComponent = IpfEfExtComponent,,IpfEfExtComponentInstall

[IpfInstall_Win10_17763_MSI.NTamd64.Components]
AddComponent = IpfEfExtComponent,,IpfEfExtComponentInstall

[IpfInstall_Win11_22621.NTamd64.Components]
AddComponent = IpfEfExtComponent,,IpfEfExtComponentInstall

[IpfInstall_Win11_22621_MSI.NTamd64.Components]
AddComponent = IpfEfExtComponent,,IpfEfExtComponentInstall

[IpfEfExtComponentInstall]
ComponentIDs = VID8086_IPFEF_1.0
Description = "Intel(R) Innovation Platform Framework Extensible Framework Component"


[IpfEfInstall.NTamd64]
CopyFiles = IpfEf_CopyFiles
AddReg = IpfEfInstall_AddReg

[IpfEfInstall.NTamd64.Services]
AddService = ,2

[IpfEfInstall.NTamd64.Events]
AddEventProvider = %IpfNamespaceMgrEtwProviderKeyGuid%,IpfNamespaceMgrEtw_Install
AddEventProvider = %IpfClientApiProxyEtwProviderKeyGuid%,IpfClientApiProxyEtw_Install
AddEventProvider = %IpfCoreProviderEtwProviderKeyGuid%,CoreProviderEtw_Install
AddEventProvider = %IpfCoreApiProxyEtwProviderKeyGuid%,CoreApiProxyEtw_Install

[IpfEf_CopyFiles]
ClientApiProxy.dll
CoreProvider.dll
CoreApiProxy.dll
NamespaceMgr.dll
ProviderCatalogProxy.dll

[IpfEfInstall_AddReg]
HKR,,"Version",,"2.2.10204.8"
HKR,,"DisplayName",,"Intel(R) Innovation Platform Framework Extensible Framework"

[IpfNamespaceMgrEtw_Install]
ProviderName = NamespaceMgrEtwProvider
ResourceFile = %13%\NamespaceMgr.dll
MessageFile  = %13%\NamespaceMgr.dll

[IpfClientApiProxyEtw_Install]
ProviderName = ClientApiProxyEtwProvider
ResourceFile = %13%\ClientApiProxy.dll
MessageFile  = %13%\ClientApiProxy.dll

[CoreProviderEtw_Install]
ProviderName = CoreProviderEtwProvider
ResourceFile = %13%\CoreProvider.dll
MessageFile  = %13%\CoreProvider.dll

[CoreApiProxyEtw_Install]
ProviderName = CoreApiProxyEtwProvider
ResourceFile = %13%\CoreApiProxy.dll
MessageFile  = %13%\CoreApiProxy.dll

;-------------------------------------------------------------------------------
; IPF EF Install Interfaces Section
;-------------------------------------------------------------------------------

[IpfEfInstall.NTamd64.Interfaces]
AddInterface = %ClientInterfaceGuid%,,IpfEfInstallInterface,0
AddInterface = %ProviderInterfaceGuid%,,IpfEfCoreProviderInstallInterface,0

[IpfEfInstallInterface]
AddReg = IpfEfInstallInterface_AddReg

[IpfEfInstallInterface_AddReg]
HKR,,"InstallDir",,%13%

[IpfEfCoreProviderInstallInterface]
AddReg = IpfEfCoreProviderInstallInterface_AddReg

[IpfEfCoreProviderInstallInterface_AddReg]
HKR,,"ProviderDir",,%13%
HKR,,"ProviderPackages",,%ProviderList%

