[Version] 
Signature = "$WINDOWS NT$" 
Class=System
ClassGUID = {4D36E97D-E325-11CE-BFC1-08002BE10318}
Provider = %INTEL% 
CatalogFile = ipf_cpu.cat
DriverVer = 12/16/2024,2.2.10204.8
PnpLockDown=1

;----------------------------------------------------------------------
; File Information
;----------------------------------------------------------------------

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
ipf_lf.sys = 1
ipf_umdf2.dll = 1
ipf_cpu.sys = 1
dsp.dv = 1
ipf_uf.exe = 1
upe_capi.dll = 1
upe_wwan.dll = 1
upe_wifi.dll = 1
upe_nvme.dll = 1
upe_battery.dll = 1
upe_nvapi.dll = 1
upe_socwc.dll = 1
upe_ipa.dll = 1
ipf_helper.exe = 1
ipf_cmp.dll = 1
ipfcore.dll = 1
ipfipc.dll = 1
ipfsrv.dll = 1
ClientApiProxy.dll = 1
CoreProvider.dll = 1
CoreApiProxy.dll = 1
NamespaceMgr.dll = 1
ProviderCatalogProxy.dll = 1

[DestinationDirs]
DefaultDestDir = 13
IpfCpu_CopyFiles = 13

;-------------------------------------------------------------------------------
; Manufacturer and Models Section
;-------------------------------------------------------------------------------

[Manufacturer]
%INTEL% = INTEL, NTamd64.10.0...17763, NTamd64.10.0...22621

[INTEL.NTamd64.10.0...17763]
%PROCADL.DeviceDesc%  = IpfInstall_Win10_17763,PCI\VEN_8086&DEV_461D
%PROCFHF.DeviceDesc%  = IpfInstall_Win10_17763,PCI\VEN_8086&DEV_3258
%PROCRPL.DeviceDesc%  = IpfInstall_Win10_17763,PCI\VEN_8086&DEV_A71D
%PROCMTL.DeviceDesc%  = IpfInstall_Win10_17763,PCI\VEN_8086&DEV_7D03
%PROCMTLS.DeviceDesc% = IpfInstall_Win10_17763,PCI\VEN_8086&DEV_AD03
%PROCLNL.DeviceDesc%  = IpfInstall_Win10_17763_MSI,PCI\VEN_8086&DEV_641D
%IPFEF.DeviceDesc%    = IpfEfInstall,SWC\VID8086_IPFEF_1.0

[INTEL.NTamd64.10.0...22621]
%PROCADL.DeviceDesc%  = IpfInstall_Win11_22621,PCI\VEN_8086&DEV_461D
%PROCFHF.DeviceDesc%  = IpfInstall_Win11_22621,PCI\VEN_8086&DEV_3258
%PROCRPL.DeviceDesc%  = IpfInstall_Win11_22621,PCI\VEN_8086&DEV_A71D
%PROCMTL.DeviceDesc%  = IpfInstall_Win11_22621,PCI\VEN_8086&DEV_7D03
%PROCMTLS.DeviceDesc% = IpfInstall_Win11_22621,PCI\VEN_8086&DEV_AD03
%PROCLNL.DeviceDesc%  = IpfInstall_Win11_22621_MSI,PCI\VEN_8086&DEV_641D
%IPFEF.DeviceDesc%    = IpfEfInstall,SWC\VID8086_IPFEF_1.0

;------------------------------------------------------------------------------
; IPF Install Section
;------------------------------------------------------------------------------

[IpfInstall_Win10_17763.NTamd64]
CopyFiles = IpfCpu_CopyFiles

[IpfInstall_Win10_17763_MSI.NTamd64]
CopyFiles = IpfCpu_CopyFiles

[IpfInstall_Win11_22621.NTamd64]
Include   = WUDFRD.inf
Needs     = WUDFRD.NT
CopyFiles = IpfCpu_CopyFiles

[IpfInstall_Win11_22621_MSI.NTamd64]
Include   = WUDFRD.inf
Needs     = WUDFRD.NT
CopyFiles = IpfCpu_CopyFiles

[IpfInstall_Win10_17763.NTamd64.Services]
AddService = ipf_lf,, IpfLfService_Install, IpfLfEtw_Install, System, ipf_lf
AddService = ipf_cpu,0x00000002, IpfCpuService_Install, IpfCpuEtw_Install, System, ipf_cpu
AddService = WUDFRd,0x000001f8, WUDFRDService_Install, IpfUfLogging_Install, Application
AddService = ipfsvc, 0x000009f8, IpfUfService_Install_Win10_17763, IpfUfSupportLogging_Install, Application, IPF

[IpfInstall_Win10_17763_MSI.NTamd64.Services]
AddService = ipf_lf,, IpfLfService_Install, IpfLfEtw_Install, System, ipf_lf
AddService = ipf_cpu,0x00000002, IpfCpuService_Install, IpfCpuEtw_Install, System, ipf_cpu
AddService = WUDFRd,0x000001f8, WUDFRDService_Install, IpfUfLogging_Install, Application
AddService = ipfsvc, 0x000009f8, IpfUfService_Install_Win10_17763, IpfUfSupportLogging_Install, Application, IPF

[IpfInstall_Win11_22621.NTamd64.Services]
Include = WUDFRD.inf
Needs = WUDFRD.NT.Services
AddService = ipf_lf,, IpfLfService_Install,, System, ipf_lf
AddService = ipf_cpu,0x00000002,IpfCpuService_Install,,System,ipf_cpu
AddService = ipfsvc,0x000009f8,IpfUfService_Install_Win11_22621,,Application,IPF

[IpfInstall_Win11_22621_MSI.NTamd64.Services]
Include = WUDFRD.inf
Needs = WUDFRD.NT.Services
AddService = ipf_lf,, IpfLfService_Install,, System, ipf_lf
AddService = ipf_cpu,0x00000002,IpfCpuService_Install,,System,ipf_cpu
AddService = ipfsvc,0x000009f8,IpfUfService_Install_Win11_22621,,Application,IPF

[IpfLfService_Install]
ServiceType = %SERVICE_KERNEL_DRIVER%
StartType = %SERVICE_DEMAND_START%
ErrorControl = %SERVICE_ERROR_NORMAL%
ServiceBinary = %13%\ipf_lf.sys
LoadOrderGroup = Base
AddReg = IpfVersion_AddReg

[IpfVersion_AddReg]
HKR,"Parameters","Version",,"1.0.11904.2707"
HKR,"Parameters","Display",,"Intel(R) Innovation Platform Framework"
HKR,"Parameters","Path",,"%13%"

[IpfCpuService_Install]
ServiceType = %SERVICE_KERNEL_DRIVER%
StartType = %SERVICE_DEMAND_START%
ErrorControl = %SERVICE_ERROR_NORMAL%
ServiceBinary = %13%\ipf_cpu.sys
LoadOrderGroup = Base

[WUDFRDService_Install]
DisplayName = %ReflectorName%
ServiceType = %SERVICE_KERNEL_DRIVER%
StartType = %SERVICE_DEMAND_START%
ErrorControl = %SERVICE_ERROR_NORMAL%
ServiceBinary = %12%\WUDFRd.sys

[IpfInstall_Win10_17763.NTamd64.HW]
AddReg = Hw_AddFilterReg
AddReg = Hw_AddLocationReg

[IpfInstall_Win10_17763_MSI.NTamd64.HW]
AddReg = Hw_AddFilterReg
AddReg = Hw_AddLocationReg
AddReg = Hw_EnableMsi

[IpfInstall_Win11_22621.NTamd64.HW]
Include = WUDFRD.inf
Needs = WUDFRD.NT.HW
AddReg = Hw_AddFilterReg
AddReg = Hw_AddLocationReg

[IpfInstall_Win11_22621_MSI.NTamd64.HW]
Include = WUDFRD.inf
Needs = WUDFRD.NT.HW
AddReg = Hw_AddFilterReg
AddReg = Hw_AddLocationReg
AddReg = Hw_EnableMsi

[Hw_AddFilterReg]
HKR,,"UpperFilters", 0x00010008, "ipf_lf"
HKR,,"UpperFilters", 0x00010008, "WUDFRd"
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GA;;;BA)"

[Hw_AddLocationReg]
HKR,,"InstallDir",,%13%

[Hw_EnableMsi]
HKR,Interrupt Management,,0x00000010
HKR,Interrupt Management\MessageSignaledInterruptProperties,,0x00000010
HKR,Interrupt Management\MessageSignaledInterruptProperties,MSISupported,0x00010001,1
HKR,Interrupt Management\MessageSignaledInterruptProperties, MessageNumberLimit, 0x00010001, 8

[IpfInstall_Win10_17763.NTamd64.Wdf]
KmdfService = ipf_lf, Wdf_KmdfSection
KmdfService = ipf_cpu, Wdf_KmdfSection
UmdfService = ipf_umdf2, Wdf_UmdfSection10.0
UmdfServiceOrder = ipf_umdf2
UmdfImpersonationLevel = Impersonation
UmdfKernelModeClientPolicy = AllowKernelModeClients 
UmdfFileObjectPolicy = AllowNullAndUnknownFileObjects
UmdfHostProcessSharing = ProcessSharingDisabled
UmdfDispatcher = FileHandle

[IpfInstall_Win10_17763_MSI.NTamd64.Wdf]
KmdfService = ipf_lf, Wdf_KmdfSection
KmdfService = ipf_cpu, Wdf_KmdfSection
UmdfService = ipf_umdf2, Wdf_UmdfSection10.0
UmdfServiceOrder = ipf_umdf2
UmdfImpersonationLevel = Impersonation
UmdfKernelModeClientPolicy = AllowKernelModeClients 
UmdfFileObjectPolicy = AllowNullAndUnknownFileObjects
UmdfHostProcessSharing = ProcessSharingDisabled
UmdfDispatcher = FileHandle

[IpfInstall_Win11_22621.NTamd64.Wdf]
KmdfService = ipf_lf, Wdf_KmdfSection
KmdfService = ipf_cpu, Wdf_KmdfSection
UmdfService = ipf_umdf2, Wdf_UmdfSection10.0
UmdfServiceOrder = ipf_umdf2
UmdfImpersonationLevel = Impersonation
UmdfKernelModeClientPolicy = AllowKernelModeClients 
UmdfFileObjectPolicy = AllowNullAndUnknownFileObjects
UmdfHostProcessSharing = ProcessSharingDisabled
UmdfDispatcher = FileHandle

[IpfInstall_Win11_22621_MSI.NTamd64.Wdf]
KmdfService = ipf_lf, Wdf_KmdfSection
KmdfService = ipf_cpu, Wdf_KmdfSection
UmdfService = ipf_umdf2, Wdf_UmdfSection10.0
UmdfServiceOrder = ipf_umdf2
UmdfImpersonationLevel = Impersonation
UmdfKernelModeClientPolicy = AllowKernelModeClients 
UmdfFileObjectPolicy = AllowNullAndUnknownFileObjects
UmdfHostProcessSharing = ProcessSharingDisabled
UmdfDispatcher = FileHandle

[Wdf_KmdfSection]
KmdfLibraryVersion = 1.11

[Wdf_UmdfSection10.0]
UmdfLibraryVersion = 2.0.0 ;hardcoded as the same inf is used for 1.11 too.
ServiceBinary = %13%\ipf_umdf2.dll

;----------------------------------------------------------------------
; ETW Support components
;----------------------------------------------------------------------

[IpfLfEtw_Install]
AddReg=IpfLfEtw_AddReg

[IpfLfEtw_AddReg]
HKLM,%IpfLfEtwProviderKey%,,%REG_SZ%,"EsifLfEtwProvider"
HKLM,%IpfLfEtwProviderKey%,"ResourceFileName",%REG_EXPAND_SZ%,"%13%\ipf_lf.sys"
HKLM,%IpfLfEtwProviderKey%,"MessageFileName",%REG_EXPAND_SZ%,"%13%\ipf_lf.sys"
HKLM,%IpfLfEtwProviderKey%,"Enabled",%REG_DWORD%,1

[IpfCpuEtw_Install]
AddReg=IpfCpuEtw_AddReg

[IpfCpuEtw_AddReg]
HKLM,%IpfCpuEtwProviderKey%,,%REG_SZ%,"DptfCpuEtwProvider"
HKLM,%IpfCpuEtwProviderKey%,"ResourceFileName",%REG_EXPAND_SZ%,"%13%\ipf_cpu.sys"
HKLM,%IpfCpuEtwProviderKey%,"MessageFileName",%REG_EXPAND_SZ%,"%13%\ipf_cpu.sys"
HKLM,%IpfCpuEtwProviderKey%,"Enabled",%REG_DWORD%,1

[IpfUfLogging_Install]
AddReg=IpfUmdf2Etw_AddReg
AddReg=IpfUmdf2EventLog_AddReg

[IpfUmdf2Etw_AddReg]
HKLM,%IpfUmdf2EtwProviderKey%,,%REG_SZ%,"EsifUmdf2EtwProvider"
HKLM,%IpfUmdf2EtwProviderKey%,"ResourceFileName",%REG_EXPAND_SZ%,"%13%\ipf_umdf2.dll"
HKLM,%IpfUmdf2EtwProviderKey%,"MessageFileName",%REG_EXPAND_SZ%,"%13%\ipf_umdf2.dll"
HKLM,%IpfUmdf2EtwProviderKey%,"Enabled",%REG_DWORD%,1

[IpfUmdf2EventLog_AddReg]
HKLM,%IpfUmdf2EventLogProviderKey%,,%REG_SZ%,"IPF"
HKLM,%IpfUmdf2EventLogProviderKey%,"ResourceFileName",%REG_EXPAND_SZ%,"%13%\ipf_umdf2.dll"
HKLM,%IpfUmdf2EventLogProviderKey%,"MessageFileName",%REG_EXPAND_SZ%,"%13%\ipf_umdf2.dll"
HKLM,%IpfUmdf2EventLogProviderKey%,"Enabled",%REG_DWORD%,1
HKLM,%IpfUmdf2EventLogProviderKey%"\ChannelReferences","Count",%REG_DWORD%,1
HKLM,%IpfUmdf2EventLogProviderKey%"\ChannelReferences\0\",,%REG_SZ%,"Application"
HKLM,%IpfUmdf2EventLogProviderKey%"\ChannelReferences\0\","Flags",%REG_DWORD%,1
HKLM,%IpfUmdf2EventLogProviderKey%"\ChannelReferences\0\","Id",%REG_DWORD%,9
HKLM,%IpfUmdf2EventLogChannelKey%,"Enabled",%REG_DWORD%,1
HKLM,%IpfUmdf2EventLogChannelKey%,"EnableLevel",%REG_DWORD%,0
HKLM,%IpfUmdf2EventLogChannelKey%,"EnableProperty",%REG_DWORD%,1
HKLM,%IpfUmdf2EventLogChannelKey%,"LoggerName",%REG_EXPAND_SZ%,"EventLog-Application"
HKLM,%IpfUmdf2EventLogChannelKey%,"MatchAnyKeyword",%REG_QWORD%,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x80
HKLM,%IpfUmdf2EventLogChannelKey%,"MatchAllKeyword",%REG_QWORD%,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00

[IpfInstall_Win11_22621.NTamd64.Events]
AddEventProvider = %IpfLfEtwProviderKeyGuid%,IpfLfEtw_Install_Win11
AddEventProvider = %IpfCpuEtwProviderKeyGuid%,IpfCpuEtw_Install_Win11
AddEventProvider = %IpfUmdf2EtwProviderKeyGuid%,IpfUmdf2Etw_Install_Win11
AddEventProvider = %IpfUmdf2EventLogProviderKeyGuid%,IpfUmdf2EventLog_Install_Win11
AddEventProvider = %IpfSvcEtwProviderKeyGuid%,IpfUfEtw_Install_Win11
AddEventProvider = %IpfSvcEventLogProviderKeyGuid%,IpfUfEventLog_Install_Win11
AddEventProvider = %IpfHelperEtwProviderKeyGuid%,IpfHelperEtw_Install_Win11
AddEventProvider = %IpfHelperEventLogProviderKeyGuid%,IpfHelperEventLog_Install_Win11
AddEventProvider = %IpfCoreEtwProviderKeyGuid%,IpfCoreEtw_Install_Win11
AddEventProvider = %IpfIpcEtwProviderKeyGuid%,IpfIpcEtw_Install_Win11

[IpfInstall_Win11_22621_MSI.NTamd64.Events]
AddEventProvider = %IpfLfEtwProviderKeyGuid%,IpfLfEtw_Install_Win11
AddEventProvider = %IpfCpuEtwProviderKeyGuid%,IpfCpuEtw_Install_Win11
AddEventProvider = %IpfUmdf2EtwProviderKeyGuid%,IpfUmdf2Etw_Install_Win11
AddEventProvider = %IpfUmdf2EventLogProviderKeyGuid%,IpfUmdf2EventLog_Install_Win11
AddEventProvider = %IpfSvcEtwProviderKeyGuid%,IpfUfEtw_Install_Win11
AddEventProvider = %IpfSvcEventLogProviderKeyGuid%,IpfUfEventLog_Install_Win11
AddEventProvider = %IpfHelperEtwProviderKeyGuid%,IpfHelperEtw_Install_Win11
AddEventProvider = %IpfHelperEventLogProviderKeyGuid%,IpfHelperEventLog_Install_Win11
AddEventProvider = %IpfCoreEtwProviderKeyGuid%,IpfCoreEtw_Install_Win11
AddEventProvider = %IpfIpcEtwProviderKeyGuid%,IpfIpcEtw_Install_Win11

[IpfLfEtw_Install_Win11]
ProviderName = EsifLfEtwProvider
ResourceFile = %13%\ipf_cpu.sys
MessageFile  = %13%\ipf_cpu.sys

[IpfCpuEtw_Install_Win11]
ProviderName = DptfCpuEtwProvider
ResourceFile = %13%\ipf_cpu.sys
MessageFile  = %13%\ipf_cpu.sys

[IpfUmdf2Etw_Install_Win11]
ProviderName = EsifUmdf2EtwProvider
ResourceFile = %13%\ipf_umdf2.dll
MessageFile  = %13%\ipf_umdf2.dll

[IpfUmdf2EventLog_Install_Win11]
ProviderName  = IPF
ResourceFile  = %13%\ipf_umdf2.dll
MessageFile   = %13%\ipf_umdf2.dll
ImportChannel = Application

[IpfUfEtw_Install_Win11]
ProviderName = EsifSvcEtwProvider
ResourceFile = %13%\ipf_uf.exe
MessageFile  = %13%\ipf_uf.exe

[IpfUfEventLog_Install_Win11]
ProviderName  = IPFUF
ResourceFile  = %13%\ipf_uf.exe
MessageFile   = %13%\ipf_uf.exe
ImportChannel = Application

[IpfHelperEtw_Install_Win11]
ProviderName = DptfHelperEtwProvider
ResourceFile = %13%\ipf_helper.exe
MessageFile  = %13%\ipf_helper.exe

[IpfHelperEventLog_Install_Win11]
ProviderName  = DPTFHELPER
ResourceFile  = %13%\ipf_helper.exe
MessageFile   = %13%\ipf_helper.exe
ImportChannel = Application

[IpfCoreEtw_Install_Win11]
ProviderName = IpfCoreEtwProvider
ResourceFile = %13%\ipfcore.dll
MessageFile  = %13%\ipfcore.dll

[IpfIpcEtw_Install_Win11]
ProviderName = IpfIpcEtwProvider
ResourceFile = %13%\ipfipc.dll
MessageFile  = %13%\ipfipc.dll

